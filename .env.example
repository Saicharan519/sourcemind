# SourceMind environment configuration.
#
# Copy this file to backend/.env and fill in your keys:
#     cp .env.example backend/.env
#
# NOTE: config.py loads ".env" relative to the working directory, and the
# backend is always run from backend/ — so the real file must live at
# backend/.env, NOT the repo root.

# === Groq API (free — get a key at https://console.groq.com/keys) ===
GROQ_API_KEY=
GROQ_MODEL_MAIN=llama-3.3-70b-versatile     # final answer generation (quality)
GROQ_MODEL_FAST=llama-3.1-8b-instant        # classification, multi-query, HyDE, etc.

# === Mistral API (free — used as the RAGAS evaluator LLM; https://console.mistral.ai) ===
# If left blank, RAGAS falls back to the Groq 8B model.
MISTRAL_API_KEY=
MISTRAL_MODEL_EVAL=mistral-small-latest

# === PostgreSQL ===
# Use 'localhost' for local dev; use 'postgres' (the compose service name) inside Docker.
DATABASE_URL=postgresql+asyncpg://sourcemind:sourcemind_secret@localhost:5432/sourcemind
POSTGRES_USER=sourcemind
POSTGRES_PASSWORD=sourcemind_secret
POSTGRES_DB=sourcemind

# === Qdrant ===
# Use 'localhost' for local dev; 'qdrant' inside Docker.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sourcemind

# === Whisper transcription (local, faster-whisper / CTranslate2) ===
WHISPER_MODEL=small                         # tiny | base | small | medium (base.en/small.en = English-only)

# === Embeddings (local, sentence-transformers) ===
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu                         # 'cuda' requires a CUDA-enabled torch build

# === Hybrid search ===
MMR_LAMBDA=0.5                               # 0 = max diversity, 1 = max relevance
MMR_FETCH_K=20                               # candidates before MMR reranking
MMR_FINAL_K=6                                # final chunks passed to the LLM
BM25_TOP_K=10                                # sparse results before RRF fusion
DENSE_TOP_K=10                               # dense results before RRF fusion

# === App ===
MAX_PDF_SIZE_MB=100
MAX_VIDEO_DURATION_MIN=120
UPLOAD_DIR=./uploads
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === RAGAS evaluation ===
RAGAS_NUM_QUESTIONS=3                        # QA pairs generated per source (10 = thorough, 3 = fast)
